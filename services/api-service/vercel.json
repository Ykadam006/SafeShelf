{
  "version": 2,
  "buildCommand": "echo 'serverless: skipping tsc build (Vercel compiles api/ at deploy time)'",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "{src/docs,node_modules/swagger-ui-dist}/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
