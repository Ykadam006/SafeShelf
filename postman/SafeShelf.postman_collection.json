          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST Users",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ada Pantry\",\n  \"email\": \"ada.pantry@example.com\",\n  \"role\": \"USER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/users",
            "description": "`role` is optional (`USER` or `ADMIN`); defaults apply when omitted."
          },
          "response": []
        },
        {
          "name": "GET Users list",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users"
          },
          "response": []
        },
        {
          "name": "GET User by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          },
          "response": []
        },
        {
          "name": "PATCH User by id",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ada Pantry (updated)\",\n  \"email\": \"ada.updated@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Send any subset of `name`, `email`, `role` — at least one field is required."
          },
          "response": []
        },
        {
          "name": "DELETE User by id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          },
          "response": []
        }
      ]
    },
    {
