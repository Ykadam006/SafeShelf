    {
      "name": "Alerts",
      "item": [
        {
          "name": "GET Alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/alerts",
            "description": "Optional query params: `userId`, `status`, `riskLevel` (see OpenAPI)."
          },
          "response": []
        },
        {
          "name": "GET Alert by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/alerts/{{alertId}}"
          },
          "response": []
        },
        {
          "name": "PATCH Alert by id",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertStatus\": \"REVIEWED\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/alerts/{{alertId}}",
            "description": "`alertStatus`: `NEW` | `REVIEWED` | `DISMISSED` | `RESOLVED`"
