    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "GET Dashboard summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/dashboard/summary",
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "disabled": true,
                  "description": "Optional UUID to scope rollups to one pantry owner."
