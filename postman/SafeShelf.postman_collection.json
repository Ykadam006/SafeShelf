        {
          "name": "GET Categories list",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pantry Items",
      "item": [
        {
          "name": "POST Pantry Items",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"name\": \"Organic peanut butter 16 oz\",\n  \"brand\": \"Example Foods Co.\",\n  \"quantity\": 2,\n  \"expirationDate\": \"2026-12-31\",\n  \"purchaseDate\": \"2026-01-15\",\n  \"storageLocation\": \"Pantry shelf B\",\n  \"barcode\": \"012345678905\",\n  \"notes\": \"Unopened\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/pantry-items",
            "description": "Replace `{{userId}}` and `{{categoryId}}` Postman variables (or paste literal UUIDs) from **Users** and **Categories** steps."
          },
          "response": []
        },
        {
          "name": "GET Pantry Items list",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/pantry-items"
          },
          "response": []
        },
        {
          "name": "GET Pantry Item by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/pantry-items/{{pantryItemId}}"
          },
          "response": []
        },
        {
          "name": "PATCH Pantry Item by id",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5,\n  \"storageLocation\": \"Refrigerator door\",\n  \"notes\": \"Opened — use within 30 days.\",\n  \"expirationDate\": \"2026-06-01\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/pantry-items/{{pantryItemId}}",
            "description": "At least one updatable field must be present."
          },
          "response": []
        },
        {
          "name": "DELETE Pantry Item by id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/pantry-items/{{pantryItemId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Recalls",
      "item": [
        {
          "name": "GET Recall search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recalls/search?query=peanut+butter",
              "query": [
                {
                  "key": "query",
                  "value": "peanut butter"
                }
              ]
            },
            "description": "Proxies recall-service FDA search via api-service."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Recall Checks",
      "item": [
        {
          "name": "POST Pantry Item recall check",
          "request": {
            "method": "POST",
