              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/recalls/check-all"
          },
          "response": []
        },
        {
          "name": "GET Pantry Item recall checks",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/pantry-items/{{pantryItemId}}/recall-checks"
